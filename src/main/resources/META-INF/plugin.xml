<idea-plugin>
    <id>dev.bartoszmaka.toggle</id>
    <name>Toggle</name>
    <vendor email="bartoszmaka95@gmail.com">bartoszmaka</vendor>
    <description><![CDATA[
        Toggles the thing under the caret: booleans (true/false), single-character pairs
        (+/-, &gt;/&lt;), and string quote styles. Configurable globally and per language.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="dev.bartoszmaka.toggle.settings.ToggleSettings"/>
        <applicationConfigurable
            parentId="tools"
            instance="dev.bartoszmaka.toggle.settings.ToggleSettingsConfigurable"
            id="dev.bartoszmaka.toggle.settings.ToggleSettingsConfigurable"
            displayName="Toggle"/>
    </extensions>

    <actions>
        <action
            id="dev.bartoszmaka.toggle.ToggleAction"
            class="dev.bartoszmaka.toggle.ToggleAction"
            text="Toggle the Thing Under Caret"
            description="Toggle boolean, operator, or quote under cursor"/>
    </actions>
</idea-plugin>
